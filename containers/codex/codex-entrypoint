#!/usr/bin/env bash
set -euo pipefail

export PATH="/usr/local/bin:/root/.nix-profile/bin:/nix/var/nix/profiles/default/bin:/run/current-system/sw/bin:/usr/bin:/bin:${PATH:-}"
export HOME="${HOME:-/home/codexapp}"
export CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
export CODEXUI_CODEX_COMMAND="${CODEXUI_CODEX_COMMAND:-/usr/local/bin/codex}"
export NPM_CONFIG_PREFIX="${NPM_CONFIG_PREFIX:-/usr/local}"
export npm_config_prefix="$NPM_CONFIG_PREFIX"
export OLLAMA_API_KEY="${OLLAMA_API_KEY:-${OLLAMA_CLOUD_API_KEY:-}}"

mkdir -p "$HOME" "$CODEX_HOME" /var/lib/docker /var/run
chmod 0700 "$CODEX_HOME" || true

if ! docker info >/dev/null 2>&1; then
  rm -f /var/run/docker.pid
  dockerd \
    --host=unix:///var/run/docker.sock \
    --data-root=/var/lib/docker \
    --storage-driver=vfs \
    >/tmp/dockerd.log 2>&1 &

  for _ in $(seq 1 60); do
    if docker info >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
fi

if ! docker info >/dev/null 2>&1; then
  echo "Docker daemon failed to become ready" >&2
  tail -n 200 /tmp/dockerd.log >&2 || true
  exit 1
fi

if [ -n "${OPENCODE_GO_API_KEY:-}${OLLAMA_API_KEY:-}" ]; then
  node /usr/local/bin/codex-provider-mux >/tmp/codex-provider-mux.log 2>&1 &
  for _ in $(seq 1 30); do
    if curl -fsS --max-time 2 http://127.0.0.1:5910/health >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
fi

node <<'NODE'
const fs = require('fs');
const path = require('path');

const codexHome = process.env.CODEX_HOME || `${process.env.HOME}/.codex`;
const statePath = path.join(codexHome, 'webui-custom-providers.json');
const hasOpenCodeGo = Boolean(process.env.OPENCODE_GO_API_KEY);
const hasOllama = Boolean(process.env.OLLAMA_API_KEY);

if (hasOpenCodeGo || hasOllama) {
  fs.mkdirSync(codexHome, { recursive: true, mode: 0o700 });

  let state = {};
  if (fs.existsSync(statePath)) {
    try {
      state = JSON.parse(fs.readFileSync(statePath, 'utf8'));
    } catch {
      state = {};
    }
  }

  const providerKeys = { ...(state.providerKeys || {}) };
  providerKeys.custom = 'managed';

  state.enabled = true;
  state.customKey = true;
  state.provider = 'custom';
  state.apiKey = 'managed';
  state.customBaseUrl = 'http://127.0.0.1:5910/v1';
  state.wireApi = 'chat';
  if (!state.model || (!state.model.startsWith('opencode-go/') && !state.model.startsWith('ollama/'))) {
    state.model = hasOpenCodeGo ? 'opencode-go/kimi-k2.6' : 'ollama/gpt-oss:120b';
  }
  state.providerKeys = providerKeys;

  fs.writeFileSync(statePath, `${JSON.stringify(state, null, 2)}\n`, { mode: 0o600 });
  fs.chmodSync(statePath, 0o600);
}
NODE

npm install -g --no-fund --no-audit codexapp@latest @openai/codex@latest

exec codexapp \
  --port 5900 \
  --no-open \
  --no-tunnel \
  --no-login \
  --sandbox-mode danger-full-access \
  --approval-policy never
