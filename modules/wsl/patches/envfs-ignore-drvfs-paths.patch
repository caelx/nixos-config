+    #[test]
+    fn parses_drvfs_mountpoints_only() {
+        let mounts = "\
+C:\\\\ /mnt/c drvfs rw,noatime 0 0
+none /usr/bin envfs rw,nosuid,nodev 0 0
+D:\\\\ /mnt/Windows\\040Drive drvfs rw,noatime 0 0
+";
+
+        assert_eq!(
+            drvfs_mountpoints_from_mounts(mounts),
+            vec![
